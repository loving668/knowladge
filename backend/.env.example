# 将此文件复制为 .env 并填入你的真实密钥
# cp .env.example .env

# DeepSeek API 配置
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MySQL 数据库（可选，默认使用 SQLite）
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=1234
# MYSQL_DATABASE=llm_wiki
